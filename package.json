{
  "name": "mp-book",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "wrangler dev src/index.ts --port 8787",
    "dev:web": "cd web && vite --port 5173",
    "build": "cd web && npm run build",
    "deploy": "npm run build && wrangler deploy",
    "lint": "tsc --noEmit && cd web && tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "@types/node": "^20.14.0",
    "@types/xml2js": "^0.4.14",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0",
    "wrangler": "^3.60.0"
  }
}
